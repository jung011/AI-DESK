<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>AI Desk Helper</title>
    <organization>com.kaflix</organization>
    <welcome    file="welcome.html"    mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <!-- 최소 macOS 12 (Monterey). Apple Silicon + Intel 둘 다 OK. -->
    <allowed-os-versions>
        <os-version min="12.0"/>
    </allowed-os-versions>

    <options
        customize="never"
        require-scripts="true"
        rootVolumeOnly="true"
        hostArchitectures="x86_64,arm64"/>

    <choices-outline>
        <line choice="default"/>
    </choices-outline>

    <choice id="default" visible="false">
        <pkg-ref id="com.kaflix.aidesk-helper"/>
    </choice>

    <pkg-ref id="com.kaflix.aidesk-helper" version="0.1.0" auth="root">
        AIDeskHelper-component.pkg
    </pkg-ref>
</installer-gui-script>
