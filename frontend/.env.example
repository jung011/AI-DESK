# Nuxt env 분리 — Spring profile 등가 패턴.
#
# - `.env.development` : `nuxt dev` 자동 로드 — 로컬 개발 (gitignore)
# - `.env.production`  : `nuxt build` 자동 로드 — prod build (gitignore)
# - `.env`             : 항상 로드 — 공통 (gitignore)
#
# 이 파일은 형식 안내용. 본인 mac 에서 `.env.development` 복사 후 사용.
#
# Vite/Nuxt 의 빌드 시점 분기는 `import.meta.dev` (frontend 코드 안) — tree-shake 로
# prod bundle 에 dev 코드가 *물리적으로 포함 안 됨*.

# ---------- 공통 ----------
# 백엔드 API base URL — runtimeConfig.public.apiBase 로 SPA 가 fetch 시 prepend.
# helm 환경에서는 nginx entrypoint 가 config.js 로 envsubst — 이 변수보다 우선.
NUXT_PUBLIC_API_BASE=http://localhost:30081

# 데스크톱 헬퍼 — 각 사용자 PC 의 localhost (절대 dev/prod 분리 X).
NUXT_PUBLIC_HELPER_BASE=http://localhost:30083

# 메타버스 3D 사무실 외부 BE URL — 빈 문자열 시 헤더 버튼 hide.
NUXT_PUBLIC_METAVERSE_URL=
